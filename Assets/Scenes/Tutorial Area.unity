  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4b697cd8774dbd049a21eb4b19d9685c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - Heh heh heh... your first test is right below us. See that key beside me? Press
    [ E ] to pick it up, then use it on the door down there to get started.
  - Once inside, you need to move those big boxes onto the floor plates. Press [
    E ] to push them, and [ Q ] to pull them back if they get stuck in a corner.
  - Keep an eye out for more keys in there to open the way forward. Push, pull, and
    unlock. Simple enough, mate... off you go.
  dialogueText: {fileID: 1932431552}
  Yes: {fileID: 512094613}
  tutorial: 0
