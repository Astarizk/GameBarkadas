--- !u!114 &1515486707
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1515486705}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4b697cd8774dbd049a21eb4b19d9685c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  lines:
  - "Alright, mate, let\u2019s see if you\u2019ve got more than just muscles. Ahead
    of you are two doors. One leads forward, the other... well, let\u2019s just say
    it leads to a very quick restart."
  - "You\u2019ll need to pick the right door four times in a row to reach the prize.
    Just walk up to your choice and press [ E ] to see if luck is on your side."
  - If you manage to survive all four, you'll find the ladder waiting for you at
    the end. Pick it up with [ E ], bring it back here, and set it against the wall
    to reach the next floor.
  - If you manage to survive all four, you'll find the ladder waiting for you at
    the end. Pick it up with [ E ], bring it back here, and set it against the wall
    to reach the next floor.
  - "Try to use your head\u2014or just guess wildly. Either way, it\u2019s entertaining
    for me! Best of luck..."
  dialogueText: {fileID: 1932431552}
  Yes: {fileID: 512094613}
  tutorial: 0
